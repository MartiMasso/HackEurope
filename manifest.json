{
  "manifest_version": 3,
  "name": "Toolbox Floating Icon",
  "description": "MVP extension that toggles a draggable floating icon on the current page.",
  "version": "0.1.0",
  "permissions": ["tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle Toolbox Floating Icon",
    "default_icon": {
      "16": "assets/logo1.png",
      "32": "assets/logo1.png",
      "48": "assets/logo1.png",
      "128": "assets/logo1.png"
    }
  },
  "icons": {
    "16": "assets/logo1.png",
    "32": "assets/logo1.png",
    "48": "assets/logo1.png",
    "128": "assets/logo1.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/icon.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
