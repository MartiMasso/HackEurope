{
  "manifest_version": 3,
  "name": "Toolbox Search Bar",
  "description": "Toggle a Google Assistant-style search bar on any page via toolbar click or Ctrl+Shift+Space.",
  "version": "0.2.0",
  "permissions": [
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle Toolbox Search Bar",
    "default_icon": {
      "16": "assets/logo1.png",
      "32": "assets/logo1.png",
      "48": "assets/logo1.png",
      "128": "assets/logo1.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space",
        "mac": "Command+Shift+Space"
      },
      "description": "Toggle the search bar"
    }
  },
  "icons": {
    "16": "assets/logo1.png",
    "32": "assets/logo1.png",
    "48": "assets/logo1.png",
    "128": "assets/logo1.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icon.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
